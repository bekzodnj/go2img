{
  "name": "indie-stack-6589",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "dev:serve": "NODE_OPTIONS=\"--import ./mocks/index.js\" react-router-serve ./build/server/index.js",
    "format": "prettier --write .",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "setup": "npx prisma generate && npx prisma migrate deploy && npx prisma db seed",
    "start": "react-router-serve ./build/server/index.js",
    "start:mocks": "NODE_OPTIONS=\"--import ./mocks/index.js\" react-router-serve ./build/server/index.js",
    "test": "vitest",
    "test:e2e:dev": "start-server-and-test dev http://localhost:3000 \"npx cypress open\"",
    "pretest:e2e:run": "npm run build",
    "test:e2e:run": "cross-env PORT=8811 start-server-and-test start:mocks http://localhost:8811 \"npx cypress run\"",
    "typecheck": "react-router typegen && tsc",
    "validate": "npm-run-all --parallel \"test -- --run\" lint typecheck test:e2e:run",
    "postinstall": "npx prisma generate"
  },
  "eslintIgnore": [
    "/node_modules",
    "/build",
    "/public/build"
  ],
